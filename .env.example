# ── Database (upload history) ──────────────────────────────────────────────
# Required for My uploads / Everyone history tables in the app.
# DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=

# Port the app listens on inside the container (docker-compose already sets this to 5000)
PORT=5000

# ── ACE SSO (disabled by default for now) ────────────────────────────────────
# Set ENABLE_SSO=true to require ACE login again.
ENABLE_SSO=false
SSO_JWT_SECRET=
SSO_LOGIN_URL=https://sso.aceelectronics.com
# Public origin used for SSO redirect_uri (DNS/NPM → host port 8095)
APP_URL=https://image.aceelectronics.com
APP_DOMAIN=aceelectronics.com

# ── SharePoint uploads (Azure AD app — GCC High) ─────────────────────────────
# App: Ace JobTravelerPhotos Access
AZURE_TENANT_ID=6ab850db-8359-47f8-9e46-ddb57a3f87bd
AZURE_CLIENT_ID=9ae5ad08-419d-41fd-a1ef-b57f014d06ba
# Prefer certificate (Workload ID / Conditional Access). Secret works if set (takes priority).
# AZURE_CLIENT_SECRET=
# Local files:
AZURE_CLIENT_CERT_PATH=./certs/ace-jobtravelerphotos.pem
AZURE_CLIENT_CERT_KEY_PATH=./certs/ace-jobtravelerphotos.key
# Portainer (no volume mounts) — paste from certs/*.pem.b64.txt and *.key.b64.txt:
# AZURE_CLIENT_CERT_PEM_BASE64=
# AZURE_CLIENT_CERT_KEY_BASE64=
SHAREPOINT_SITE_HOSTNAME=aceelectronics.sharepoint.us
SHAREPOINT_SITE_PATH=/sites/jobtravelerphotos
# Required when the app uses Sites.Selected (hostname lookup often 403s).
# Get via Graph (admin): GET /sites/aceelectronics.sharepoint.us:/sites/jobtravelerphotos
# SHAREPOINT_SITE_ID=aceelectronics.sharepoint.us,8302eb5d-5510-48db-969d-dc8a13460a5a,90e97411-32c3-4011-a5d9-4219a64ccb20
# SHAREPOINT_DRIVE_ID=

# ── SFTP Excel sync (primary — daily Sage Open Orders dump) ──────────────────
SFTP_HOST=192.2.150.2
SFTP_PORT=22
SFTP_USER=ppadm
# Prefer base64 so Portainer does not mangle "$" characters:
#   echo -n '235$$hPW#@!' | base64   →   MjM1JCRoUFcjQCE=
SFTP_PASSWORD_B64=MjM1JCRoUFcjQCE=
# Plain password (optional if B64 is set). If Portainer collapses "$$"→"$",
# SFTP_PASSWORD_DOLLAR_ESCAPE=double restores them.
SFTP_PASSWORD=
SFTP_REMOTE_DIRS=/mnt/sage,/mnt/import
# ENABLE_EXCEL_SFTP_SYNC=true

# ── Google Drive (unused — images → SharePoint, Excel → SFTP) ────────────────
# Legacy gdrive.ts remains in the tree but is not used for Excel sync.
# ENABLE_EXCEL_DRIVE_SYNC=false

# ── Database ──────────────────────────────────────────────────────────────
# DATABASE_URL=postgres://user:password@host:5432/dbname
