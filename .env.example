# Port the app listens on inside the container (docker-compose already sets this to 5000)
PORT=5000

# ── ACE SSO ──────────────────────────────────────────────────────────────────
# Must match ace-auth / other ACE apps (same signing secret).
SSO_JWT_SECRET=
SSO_LOGIN_URL=https://sso.aceelectronics.com
# Public origin used for SSO redirect_uri (DNS/NPM → host port 8095)
APP_URL=https://image.aceelectronics.com
APP_DOMAIN=aceelectronics.com

# ── SharePoint uploads (Azure AD app — GCC High) ─────────────────────────────
# App registration needs Sites.Selected (or broader Sites.ReadWrite.All) on
# graph.microsoft.us for site aceelectronics.sharepoint.us/sites/jobtravelerphotos
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SHAREPOINT_SITE_HOSTNAME=aceelectronics.sharepoint.us
SHAREPOINT_SITE_PATH=/sites/jobtravelerphotos
# Optional — leave empty to use the site's default Documents drive
# SHAREPOINT_DRIVE_ID=

# ── SFTP Excel sync (primary — daily Sage Open Orders dump) ──────────────────
# Host dumps "Open Order All Qty Only_<date>.xlsx" under /mnt/sage or /mnt/import.
# When set, the scheduler (7:20 AM ET) and "Check for Updates" pull via SFTP,
# save as OpenOrdersAllQtyOnly_<ts>.xlsx, and reload WO/part cache.
SFTP_HOST=192.2.150.2
SFTP_PORT=22
SFTP_USER=ppadm
SFTP_PASSWORD=
# Comma-separated dirs to search (first match set wins after newest-file sort)
SFTP_REMOTE_DIRS=/mnt/sage,/mnt/import
# Optional — set false to disable even when credentials are present
# ENABLE_EXCEL_SFTP_SYNC=true

# ── Google Drive Excel sync (fallback — Replit connectors only) ──────────────
# Used only when SFTP is not configured, or as fallback if SFTP fails.
# GOOGLE_DRIVE_KSALERT_FOLDER_ID=1ixVvva0yj1FyytYBjj0DRuPNT4i76H76
# ENABLE_EXCEL_DRIVE_SYNC=false

# ── Database ──────────────────────────────────────────────────────────────
# Not required today — the app uses in-memory storage (MemStorage).
# DATABASE_URL=postgres://user:password@host:5432/dbname
