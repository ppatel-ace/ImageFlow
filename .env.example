# Port the app listens on inside the container (docker-compose already sets this to 5000)
PORT=5000

# ── ACE SSO ──────────────────────────────────────────────────────────────────
# Must match ace-auth / other ACE apps (same signing secret).
SSO_JWT_SECRET=
SSO_LOGIN_URL=https://sso.aceelectronics.com
APP_URL=https://imageflow.aceelectronics.com
APP_DOMAIN=aceelectronics.com

# ── SharePoint uploads (Azure AD app — GCC High) ─────────────────────────────
# App registration needs Sites.Selected (or broader Sites.ReadWrite.All) on
# graph.microsoft.us for site aceelectronics.sharepoint.us/sites/jobtravelerphotos
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SHAREPOINT_SITE_HOSTNAME=aceelectronics.sharepoint.us
SHAREPOINT_SITE_PATH=/sites/jobtravelerphotos
# Optional — leave empty to use the site's default Documents drive
# SHAREPOINT_DRIVE_ID=

# ── Google Drive (Excel / work-order sync only — known gap outside Replit) ───
# Image uploads now go to SharePoint. Excel auto-update still uses gdrive.ts /
# Replit connectors until migrated.
# GOOGLE_DRIVE_KSALERT_FOLDER_ID=1ixVvva0yj1FyytYBjj0DRuPNT4i76H76

# ── Database ──────────────────────────────────────────────────────────────
# Not required today — the app uses in-memory storage (MemStorage).
# DATABASE_URL=postgres://user:password@host:5432/dbname
