# Port the app listens on inside the container (docker-compose already sets this to 5000)
PORT=5000

# ── Google Drive uploads ─────────────────────────────────────────────────────
# NOT YET FUNCTIONAL OUTSIDE REPLIT.
# The app currently authenticates to Google Drive using Replit's built-in
# connector system (server/gdrive.ts -> @replit/connectors-sdk), which only
# works when running inside Replit's own infrastructure. On Portainer/self-hosted
# Docker there is no equivalent, so /api/upload/gdrive and the Excel
# auto-update job will fail until this is replaced with a Google Service
# Account (recommended) or a self-managed OAuth2 flow. See chat notes below.
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account", ...}   # planned, not yet implemented
# GOOGLE_DRIVE_ACE_ROOT_FOLDER_ID=                              # planned, not yet implemented
# GOOGLE_DRIVE_KSALERT_FOLDER_ID=1ixVvva0yj1FyytYBjj0DRuPNT4i76H76

# ── Database ──────────────────────────────────────────────────────────────
# Not required today — the app uses in-memory storage (MemStorage). Only add
# this if/when the app is switched over to persistent PostgreSQL storage.
# DATABASE_URL=postgres://user:password@host:5432/dbname
